# Port the Express API listens on.
PORT=4000

# Python interpreter used to spawn the fairaudit CLI for live audit runs
# (POST /api/audits/:domain/run). Must have `engine/requirements.txt`
# installed, e.g. via `pip install -r ../engine/requirements.txt`.
PYTHON_BIN=python3

# Absolute or relative (from server/) path to the engine package, used as
# the cwd when spawning the CLI.
ENGINE_DIR=../engine
